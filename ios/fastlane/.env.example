# Copy to fastlane/.env (gitignored) or export in your shell.
# Never commit .p8 keys or real passwords.

# Apple Developer Team ID (10 chars) — automatic signing
DEVELOPMENT_TEAM=
# FASTLANE_TEAM_ID=

# App Store Connect API key (recommended for CI / non-interactive upload)
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXXX.p8

# Alternative: Apple ID + app-specific password (interactive or FASTLANE_PASSWORD)
# FASTLANE_APPLE_ID=
# FASTLANE_PASSWORD=
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=
