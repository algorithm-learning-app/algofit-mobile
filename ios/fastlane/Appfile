app_identifier("com.algofit.algofit")

# Apple Developer Team ID (10 characters). Set FASTLANE_TEAM_ID or DEVELOPMENT_TEAM.
team_id(ENV["FASTLANE_TEAM_ID"] || ENV["DEVELOPMENT_TEAM"]) if ENV["FASTLANE_TEAM_ID"] || ENV["DEVELOPMENT_TEAM"]

# Optional: Apple ID for password-based upload (prefer App Store Connect API key).
apple_id(ENV["FASTLANE_APPLE_ID"]) if ENV["FASTLANE_APPLE_ID"]
